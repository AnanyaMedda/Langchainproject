import logging
from typing import Tuple
from urllib.request import Request, urlopen
from urllib.parse import urlparse
from xml.etree import ElementTree as ET
from lxml import html

logger = logging.getLogger(__name__)

def get_base_url_and_sitemap(url: str) -> Tuple[str, str]:
    p = urlparse(url)
    return f"{p.scheme}://{p.netloc}", f"{p.scheme}://{p.netloc}/sitemap.xml"

def fetch_sitemap_urls(sitemap_url: str, filter_prefix: str) -> list[str]:
    try:
        with urlopen(Request(sitemap_url, headers={'User-Agent': 'Mozilla/5.0'}, method="GET"), timeout=10) as res:
            return list({e.text.strip() for e in ET.fromstring(res.read()).iter() 
                         if 'loc' in e.tag and e.text and e.text.strip().startswith(filter_prefix)})
    except Exception as e:
        logger.error(f"Sitemap fetch failed for {sitemap_url}: {e}")
        return [filter_prefix]

def fetch_and_extract_text(url: str) -> str:
    try:
        with urlopen(Request(url, headers={'User-Agent': 'Mozilla/5.0'}), timeout=10) as res:
            tree = html.fromstring(res.read())
            for elem in tree.xpath('//script | //style | //nav | //footer'):
                elem.drop_tree()
            return ' '.join(tree.text_content().split())
    except Exception as e:
        logger.error(f"Extraction failed for {url}: {e}")
        return ""

