async def ingest_url_to_knowledge_base(
        self, id: UUID, user: User, url: str, file_controller: FileController
    ):
        base_url, sitemap_url = get_base_url_and_sitemap(url)
        urls = fetch_sitemap_urls(sitemap_url, filter_prefix=url)
        cuid_generator = cuid_wrapper()

        extracted_files = []
        for target_url in urls:
            text = fetch_and_extract_text(target_url)
            if not text:
                continue

            content = text.encode("utf-8")
            file_name = "scraped_page"
            file_extension = "txt"
            new_file_name = f"{file_name}_{cuid_generator()}.{file_extension}"

            file_path = file_controller._get_local_file_path(new_file_name)
            dir_path = file_path.parent
            if not dir_path.exists():
                dir_path.mkdir(parents=True, exist_ok=True)

            async with aiofiles.open(file_path, "wb") as saved_file:
                await saved_file.write(content)

            document = FileCreate(
                filename=new_file_name,
                original_filename=target_url,
                content_type="text/plain",
                content_length=len(content),
                owner_id=user.id,
                is_private=False,
            )
            created_file = file_controller.create(File.model_validate(document))
            extracted_files.append(created_file)

        if extracted_files:
            self.attach_file_to_knowledge_base(id, user, extracted_files)
            await self.enqueue_knowledge_base_for_extraction(id, user)

        return self.get_knowledge_base(id, user)
