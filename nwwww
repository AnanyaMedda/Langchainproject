                urls_to_scrape.append(u)

    scraped_results = []
    
    # 2. Configure the crawler for high-quality extraction
    browser_config = BrowserConfig(
        headless=True,
    )

    run_config = CrawlerRunConfig(
        cache_mode=CacheMode.BYPASS,   # Always fetch fresh content
        wait_for="css:body",           # Wait for the page body to load
        remove_overlay_elements=True,  # Remove popups/modals
        process_iframes=True,          # Pull content from iframes
        magic=True                     # Automated handling of consent/popups
    )

    try:
        async with AsyncWebCrawler(config=browser_config) as crawler:
            for target_url in urls_to_scrape:
                try:
                    result = await crawler.arun(url=target_url, config=run_config)
                    
                    if result.success:
                        # Extract clean content (handle both string and object markdown results)
                        content = result.markdown
                        if hasattr(content, "raw_markdown"):
                            content = content.raw_markdown
                        
                        if not content:
                            content = result.cleansed_html
                            
                        scraped_results.append(
                            ScrapedResultPayload(url=target_url, result=content)
                        )
                    else:
                        logger.error(f"Crawl failed for {target_url}: {result.error_message}")
                except Exception as e:
                    logger.error(f"Failed to scrape {target_url}: {e}")
    except Exception as e:
        return f"Error initializing scraper: {e}"

    if not scraped_results:
        return f"Failed to scrape any content from {url} or its related pages."

    # 3. Get the user object
    user = session.get(User, runtime.context.user_id)
    if not user:
        return "Error: Could not authenticate user for ingestion."

    # 4. Ingest the scraped results into the Knowledge Base
    payload = IngestScrapedRequest(results=scraped_results)
    try:
        await runtime.context.knowledge_base_controller.ingest_scraped_results(
            id=runtime.context.knowledge_base_id,
            user=user,
            payload=payload,
            file_controller=runtime.context.file_controller
        )
    except Exception as e:
        return f"Failed to ingest scraped content into the Knowledge Base: {e}"
        
    full_content = "\n\n---\n\n".join(
        f"URL: {res.url}\nContent:\n{res.result}" for res in scraped_results
    )
    
    return (
        f"Success: Scraped and queued {len(scraped_results)} pages (including {url}) "
        f"for ingestion into the Knowledge Base. The content will be parsed and embedded shortly.\n\n"
        f"Here is the full extracted content from the pages:\n\n{full_content}"
    )

