)
def enqueue_url_scraping(
    user: CurrentUser,
    controller: KnowledgeBaseControllerDeps,
    id: UUID,
    body: IngestUrlsRequest,
):
    """
    Queue one Celery task per URL.  Each task independently:
      1. Discovers related pages from the sitemap
      2. Crawls & extracts markdown content
      3. Saves a file to the KB
      4. Generates and stores vector embeddings

    Returns immediately with the list of queued URLs.
    """
    return controller.enqueue_url_scraping(id, user, body)
