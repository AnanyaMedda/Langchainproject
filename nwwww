
@app.task(name="scrape_and_ingest_url", base=BaseTask)
def scrape_and_ingest_url(url: str, knowledge_base_id: str, user_id: str):
    from crawl4ai import AsyncWebCrawler, BrowserConfig, CrawlerRunConfig, CacheMode
    from src.modules.scrapper.controller import ScrapeController
    from src.modules.knowledge_base.schema import IngestScrapedRequest, ScrapedResultPayload
    from src.models.models import User
    
    knowledge_base_id_uuid = UUID(str(knowledge_base_id))
    user_id_uuid = UUID(str(user_id))

    if ctx.loop is None:
        raise Exception("Event loop not initialized.")

    if ctx.kafka_producer is None:
        raise Exception("Kafka Producer not initialized.")

    if ctx.vector_db is None:
        raise Exception("Vector DB not initialized.")

    with db_session() as session:
        knowledge_base_controller = ctx.factory.get_knowledge_base_controller(
            db_session=session,
            vector_db=ctx.vector_db,
            kafka_producer=ctx.kafka_producer,
        )
        file_controller = ctx.factory.get_file_controller(db_session=session)
        scrape_controller = ScrapeController(session)
        
        user = session.get(User, user_id_uuid)
        if not user:
            logger.error(f"User {user_id} not found.")
            return

        # 1. Discover related URLs from sitemap
        try:
            discovered_urls = scrape_controller.discover_urls_from_sitemap(url)
        except Exception as e:
            logger.warning(f"Sitemap discovery failed: {e}")
            discovered_urls = []
            
        urls_to_scrape = [url]
        for u in discovered_urls:
            if u != url and len(urls_to_scrape) < 5:
                urls_to_scrape.append(u)

        scraped_results = []
        
        # 2. Scrape all URLs
        browser_config = BrowserConfig(headless=True)
        run_config = CrawlerRunConfig(cache_mode=CacheMode.BYPASS, wait_for="css:body", magic=True, remove_overlay_elements=True)

        async def run_crawler():
            async with AsyncWebCrawler(config=browser_config) as crawler:
                for target_url in urls_to_scrape:
                    try:
                        result = await crawler.arun(url=target_url, config=run_config)
                        if result.success:
                            markdown_content = result.markdown.raw_markdown if hasattr(result.markdown, "raw_markdown") else result.markdown
                            content = markdown_content or result.cleansed_html
                            scraped_results.append(ScrapedResultPayload(url=target_url, result=content))
                    except Exception as e:
                        logger.error(f"Failed to scrape {target_url}: {e}")

        ctx.loop.run_until_complete(run_crawler())

        if not scraped_results:
            logger.error(f"Failed to scrape any content from {url}.")
            return

        # 3. Save ALL results to Knowledge Base
        try:
            ctx.loop.run_until_complete(
                knowledge_base_controller.ingest_scraped_results(
                    id=knowledge_base_id_uuid,
                    user=user,
                    payload=IngestScrapedRequest(results=scraped_results),
                    file_controller=file_controller
                )
            )
        except Exception as e:
            logger.error(f"KB Ingestion error: {e}")
