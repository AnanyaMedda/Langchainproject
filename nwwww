            # Create file from scraped content
            file = await file_controller.create_file_from_content(
                user_id=user.id,
                original_filename=original_filename,
                content=result.result,
                content_type="text/markdown"
            )
            files_to_attach.append(file)

        # Attach the new files to the knowledge base
        self.attach_file_to_knowledge_base(id, user, files_to_attach)

        from src.celery.tasks import store_embeddings

        for file, result in zip(files_to_attach, payload.results):
            # Since content is already extracted, we mark it as EXTRACTED
